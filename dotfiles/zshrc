### Common ZSH setup (universal) ###

# oh-my-zsh configuration
ZSH=$HOME/.oh-my-zsh
ZSH_THEME="danielge"
USE_OH_MY_ZSH=true

source /opt/homebrew/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh

if [ $USE_OH_MY_ZSH = 'true' ]; then
    COMPLETION_WAITING_DOTS="true"

    # Auto-update configuration: don't auto-update, but remind every 2 weeks
    zstyle ':omz:update' mode reminder
    zstyle ':omz:update' frequency 14

    plugins=(bazel brew)
    source $ZSH/oh-my-zsh.sh
    unsetopt correct_all

else
    if [ ! "$ZSH_THEME" = ""  ]; then
        if [ -f "$ZSH_CUSTOM/$ZSH_THEME.zsh-theme" ]; then
            source "$ZSH_CUSTOM/$ZSH_THEME.zsh-theme"
        elif [ -f "$ZSH_CUSTOM/themes/$ZSH_THEME.zsh-theme" ]; then
            source "$ZSH_CUSTOM/themes/$ZSH_THEME.zsh-theme"
        else
            source "$ZSH/themes/$ZSH_THEME.zsh-theme"
        fi
    fi
fi

# Override git_prompt_info to avoid always checking for clean directory
function git_prompt_info() {
  ref=$(git symbolic-ref HEAD 2> /dev/null) || return
  echo "$ZSH_THEME_GIT_PROMPT_PREFIX${ref#refs/heads/}${ZSH_THEME_GIT_PROMPT_CLEAN}${ZSH_THEME_GIT_PROMPT_SUFFIX}"
}

source ~/bin/z.sh

# Start an HTTP server from a directory, optionally specifying the port
function server() {
    local port="${1:-8000}"
    ( sleep 2; open "http://localhost:${port}/" ) &
    python3 -m http.server "$port"
}

source $HOME/.aliases

# PATH configuration
export PATH="$HOME/bin:$PATH"

# Set ripgrep config path
export RIPGREP_CONFIG_PATH="$HOME/.ripgreprc"

[ -f ~/.fzf.zsh ] && source ~/.fzf.zsh
